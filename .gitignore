# 依赖
node_modules/

# 日志
logs/
*.log
npm-debug.log*

# 状态文件
data/setup-states/*.json

# 备份
*.bak
backups/

# 环境
# Environment variables
.env
.env.local
.env.*.local

# API Keys and Secrets
*.key
*.pem
*.crt
**/.db_key
**/data/.db_key

# Sensitive files
**/memory/*key*.md
**/memory/*secret*.md
**/memory/*credential*.md

# Prevent nested git repositories in skills directory
skills/**/.git/
skills/**/.gitignore

# 数据库
*.db
*.sqlite
